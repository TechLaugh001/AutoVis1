import httpx
import json
import logging
from tenacity import retry, stop_after_attempt, wait_exponential
from config.settings import settings
from typing import Optional, List, Dict, Any

logger = logging.getLogger(__name__)

class AIClient:
    def __init__(self):
        self.api_type = settings.AI_API_TYPE
        self.api_key = settings.AI_API_KEY
        self.base_url = settings.AI_API_BASE_URL.rstrip('/')
        self.model = settings.AI_MODEL
        self.timeout = httpx.Timeout(30.0, connect=5.0)
        proxies = {}
        if settings.HTTP_PROXY:
            proxies["http://"] = settings.HTTP_PROXY
        if settings.HTTPS_PROXY:
            proxies["https://"] = settings.HTTPS_PROXY
        self.client = httpx.AsyncClient(timeout=self.timeout, proxies=proxies if proxies else None)

    def _get_headers(self) -> dict:
        if self.api_type in ["openai", "deepseek", "moonshot", "doubao"]:
            return {
                "Authorization": f"Bearer {self.api_key}",
                "Content-Type": "application/json"
            }
        elif self.api_type == "wenxin":
            return {"Content-Type": "application/json"}
        else:
            raise ValueError(f"Unsupported API type: {self.api_type}")

    async def close(self):
        await self.client.aclose()

    @retry(stop=stop_after_attempt(3), wait=wait_exponential(multiplier=1, min=2, max=10))
    async def chat_completion(
        self,
        messages: list,
        stream: bool = False,
        tools: Optional[List[Dict]] = None,
        tool_choice: Optional[str] = "auto"
    ) -> Any:
        headers = self._get_headers()
        url = f"{self.base_url}/chat/completions"
        payload = {
            "model": self.model,
            "messages": messages,
            "stream": stream
        }
        if tools:
            payload["tools"] = tools
            payload["tool_choice"] = tool_choice

        if stream:
            async with self.client.stream("POST", url, json=payload, headers=headers) as response:
                response.raise_for_status()
                async for line in response.aiter_lines():
                    if line.startswith("data: "):
                        data = line[6:]
                        if data == "[DONE]":
                            break
                        yield data
        else:
            resp = await self.client.post(url, json=payload, headers=headers)
            resp.raise_for_status()
            return resp.json()
