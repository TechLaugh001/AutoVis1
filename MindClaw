from sqlalchemy.orm import Session
from utils.database import SessionLocal, Conversation
from .ai_client import AIClient
from .security import sanitize_input
from memory.long_term import LongTermMemory
from planner.planner import Planner
from tools.registry import ToolRegistry
import json
import logging

logger = logging.getLogger(__name__)

class MindClawAgent:
    def __init__(self, user_id: int, ai_client: AIClient, session_id: str = "default"):
        self.user_id = user_id
        self.session_id = session_id
        self.client = ai_client
        self.messages = self._load_history()
        self.long_term_memory = LongTermMemory(str(user_id))
        self.planner = Planner(ai_client, ToolRegistry)

    def _load_history(self, limit=10):
        db = SessionLocal()
        try:
            history = db.query(Conversation).filter_by(
                user_id=self.user_id, session_id=self.session_id
            ).order_by(Conversation.id.desc()).limit(limit).all()
            msgs = []
            for msg in reversed(history):
                msgs.append({"role": "user", "content": msg.user_message})
                msgs.append({"role": "assistant", "content": msg.assistant_message})
            return msgs
        finally:
            db.close()

    async def run_stream(self, user_input: str):
        clean_input = sanitize_input(user_input)

        if clean_input.startswith("/plan "):
            task = clean_input[6:].strip()
            async for chunk in self.planner.plan_and_execute(task):
                yield chunk
            return

        memories = await self.long_term_memory.recall(clean_input)
        if memories:
            context = "\n".join(memories[:3])
            enhanced_input = f"[相关记忆]\n{context}\n[当前问题]\n{clean_input}"
        else:
            enhanced_input = clean_input

        self.messages.append({"role": "user", "content": enhanced_input})

        full_response = ""
        try:
            async for chunk_data in self.client.chat_completion(self.messages, stream=True):
                if chunk_data:
                    try:
                        chunk = json.loads(chunk_data)
                        delta = chunk["choices"][0]["delta"].get("content", "")
                        if delta:
                            full_response += delta
                            yield delta
                    except json.JSONDecodeError:
                        continue
        except Exception as e:
            logger.error(f"Stream error: {e}")
            yield f"Error: {str(e)}"
        finally:
            self.messages.append({"role": "assistant", "content": full_response})
            self._save_to_db(clean_input, full_response)

    def _save_to_db(self, user_msg, assistant_msg):
        db = SessionLocal()
        try:
            conv = Conversation(
                user_id=self.user_id,
                session_id=self.session_id,
                user_message=user_msg,
                assistant_message=assistant_msg
            )
            db.add(conv)
            db.commit()
        except Exception as e:
            logger.error(f"Save to DB failed: {e}")
            db.rollback()
        finally:
            db.close()
