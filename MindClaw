import json
from core.ai_client import AIClient
from tools.registry import ToolRegistry
import logging

logger = logging.getLogger(__name__)

class Planner:
    def __init__(self, ai_client: AIClient, tool_registry: ToolRegistry):
        self.client = ai_client
        self.tools = tool_registry

    async def plan_and_execute(self, task: str, max_steps=10):
        messages = [
            {"role": "system", "content": "你是一个能调用工具的助手。请逐步思考并执行任务。"},
            {"role": "user", "content": task}
        ]
        for step in range(max_steps):
            resp = await self.client.chat_completion(
                messages=messages,
                tools=self.tools.list_schemas(),
                tool_choice="auto"
            )
            msg = resp['choices'][0]['message']
            messages.append(msg)

            if msg.get('tool_calls'):
                for tool_call in msg['tool_calls']:
                    tool_name = tool_call['function']['name']
                    args = json.loads(tool_call['function']['arguments'])
                    tool = self.tools.get(tool_name)
                    if tool:
                        logger.info(f"调用工具 {tool_name} 参数 {args}")
                        result = await tool.run(**args)
                        messages.append({
                            "role": "tool",
                            "tool_call_id": tool_call['id'],
                            "content": str(result)
                        })
                    else:
                        messages.append({
                            "role": "tool",
                            "tool_call_id": tool_call['id'],
                            "content": f"错误：工具 {tool_name} 不存在"
                        })
            else:
                return msg['content']
        return "超过最大步骤数，任务未完成。"
