            persist_directory=settings.VECTOR_STORE_PATH
        ))
        self.collection = self.client.get_or_create_collection(collection_name)
        self.embedding_model = None
        if not settings.EMBEDDING_MODEL.startswith("text-embedding"):
            self.embedding_model = SentenceTransformer(settings.EMBEDDING_MODEL)

    async def add(self, text: str, metadata: dict, embedding=None):
        if embedding is None:
            if self.embedding_model:
                embedding = self.embedding_model.encode(text).tolist()
            else:
                embedding = text
        await asyncio.to_thread(
            self.collection.add,
            documents=[text],
            metadatas=[metadata],
            embeddings=[embedding] if isinstance(embedding, list) else None,
            ids=[str(uuid.uuid4())]
        )

    async def search(self, query: str, n_results=5):
        results = await asyncio.to_thread(
            self.collection.query,
            query_texts=[query],
            n_results=n_results
        )
        return results
